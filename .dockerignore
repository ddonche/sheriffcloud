FROM debian:trixie-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    ca-certificates curl unzip nginx \
    && rm -rf /var/lib/apt/lists/*

RUN curl "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o "awscliv2.zip" && \
    unzip awscliv2.zip && ./aws/install && \
    rm -rf aws awscliv2.zip

COPY dist/        /app/dist/
COPY goblin       /app/goblin
COPY start.sh     /app/start.sh
COPY sync_portal.sh /app/sync_portal.sh
COPY nginx.conf   /etc/nginx/nginx.conf

RUN chmod +x /app/goblin /app/start.sh /app/sync_portal.sh && \
    ln -sf /app/goblin /usr/local/bin/goblin

EXPOSE 8080
CMD ["sh", "/app/start.sh"]
```

**.dockerignore** — exclude everything except what's explicitly needed:
```
*
!dist/**
!goblin
!start.sh
!sync_portal.sh
!nginx.conf